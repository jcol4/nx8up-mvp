generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_creators {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerk_user_id              String                  @unique
  email                      String                  @unique
  age                        Int?
  location                   String?
  language                   String[]
  platform                   String[]
  subs_followers             Int?
  engagement_rate            Decimal?                @db.Decimal(5, 2)
  content_type               String[]
  game_category              String[]
  created_at                 DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?               @default(now()) @db.Timestamptz(6)
  twitch_broadcaster_type    String?
  twitch_created_at          DateTime?               @db.Timestamptz(6)
  twitch_description         String?
  twitch_id                  String?                 @unique
  twitch_profile_image       String?
  twitch_synced_at           DateTime?               @db.Timestamptz(6)
  twitch_username            String?
  youtube_avg_views          Int?
  youtube_channel_id         String?                 @unique
  youtube_channel_name       String?
  youtube_handle             String?
  youtube_subscribers        Int?
  youtube_synced_at          DateTime?               @db.Timestamptz(6)
  youtube_top_categories     String[]
  average_vod_views          Int?
  twitch_access_token        String?
  twitch_refresh_token       String?
  twitch_subscriber_count    Int?
  twitch_token_expires_at    DateTime?               @db.Timestamptz(6)
  youtube_access_token       String?
  youtube_refresh_token      String?
  youtube_token_expires_at   DateTime?               @db.Timestamptz(6)
  youtube_watch_time_hours   Int?
  audience_age_min           Int?
  audience_age_max           Int?
  audience_locations         String[]
  youtube_member_count       Int?
  creator_types              String[]
  content_style              String[]
  audience_interests         String[]
  preferred_campaign_types   String[]
  preferred_product_types    String[]
  primary_platform           String?
  is_available               Boolean                 @default(true)
  max_campaigns_per_month    Int?
  audience_gender            String[]                @default([])
  creator_size               String?
  stripe_connect_id          String?
  stripe_onboarding_complete Boolean                 @default(false)
  applications               campaign_applications[]

  @@index([average_vod_views])
  @@index([content_type], type: Gin)
  @@index([engagement_rate])
  @@index([game_category], type: Gin)
  @@index([language], type: Gin)
  @@index([platform], type: Gin)
  @@index([subs_followers])
  @@index([twitch_id])
  @@index([twitch_broadcaster_type])
  @@index([youtube_channel_id])
  @@index([youtube_subscribers])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sponsors {
  id                       String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerk_user_id            String                             @unique
  email                    String                             @unique
  company_name             String?
  location                 String?
  language                 String[]
  budget_min               Int?
  budget_max               Int?
  min_avg_viewers          Int?
  min_subs_followers       Int?
  min_engagement_rate      Decimal?                           @db.Decimal(5, 2)
  platform                 String[]
  content_type             String[]
  game_category            String[]
  created_at               DateTime?                          @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                          @default(now()) @db.Timestamptz(6)
  age_restricted           Boolean                            @default(false)
  age_restriction_type     String?
  preferred_payment_method String?                            @default("card")
  stripe_customer_id       String?
  campaigns                campaigns[]
  age_restriction_requests sponsor_age_restriction_requests[]

  @@index([budget_max])
  @@index([budget_min])
  @@index([content_type], type: Gin)
  @@index([game_category], type: Gin)
  @@index([language], type: Gin)
  @@index([min_avg_viewers])
  @@index([min_engagement_rate])
  @@index([min_subs_followers])
  @@index([platform], type: Gin)
}

model admins {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerk_user_id String    @unique
  email         String    @unique
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model campaigns {
  id                          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sponsor_id                  String                  @db.Uuid
  title                       String
  description                 String?
  status                      String                  @default("draft")
  budget                      Int?
  platform                    String[]
  content_type                String[]
  game_category               String[]
  min_avg_viewers             Int?
  min_subs_followers          Int?
  min_engagement_rate         Decimal?                @db.Decimal(5, 2)
  creative_package            String[]
  created_at                  DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?               @default(now()) @db.Timestamptz(6)
  min_audience_age            Int?
  max_audience_age            Int?
  required_audience_locations String[]
  campaign_code               String?                 @unique
  brand_name                  String?
  objective                   String?
  campaign_type               String?
  payment_model               String?
  start_date                  DateTime?               @db.Timestamptz(6)
  end_date                    DateTime?               @db.Timestamptz(6)
  product_name                String?
  product_type                String?
  target_genders              String[]
  target_cities               String?
  target_interests            String[]
  creator_types               String[]
  creator_sizes               String[]
  creator_count               Int?
  num_videos                  Int?
  video_includes              String[]
  num_streams                 Int?
  min_stream_duration         Int?
  num_posts                   Int?
  num_short_videos            Int?
  content_guidelines          String?
  must_include_link           Boolean                 @default(false)
  must_include_promo_code     Boolean                 @default(false)
  must_tag_brand              Boolean                 @default(false)
  landing_page_url            String?
  tracking_type               String?
  conversion_goal             String?
  legal_age_restriction       String?
  is_direct_invite            Boolean                 @default(false)
  num_youtube_shorts          Int?
  num_twitch_clips            Int?
  stripe_authorized_amount    Int?
  stripe_payment_intent_id    String?
  stripe_charge_id            String?
  preferred_payment_method    String?                 @default("card")
  applications                campaign_applications[]
  sponsor                     sponsors                @relation(fields: [sponsor_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sponsor_id])
  @@index([campaign_code])
  @@index([platform], type: Gin)
  @@index([content_type], type: Gin)
  @@index([game_category], type: Gin)
  @@index([end_date])
}

model campaign_applications {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id            String            @db.Uuid
  creator_id             String            @db.Uuid
  status                 String            @default("pending")
  message                String?
  submitted_at           DateTime?         @default(now()) @db.Timestamptz(6)
  app_audience_age_min   Int?
  app_audience_age_max   Int?
  app_audience_locations String[]
  app_location           String?
  app_media_types        String[]
  tracking_short_code    String?           @unique
  campaign               campaigns         @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  creator                content_creators  @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  deal_submission        deal_submissions?
  link_clicks            link_clicks[]

  @@unique([campaign_id, creator_id])
  @@index([campaign_id])
  @@index([creator_id])
  @@index([status])
}

model deal_submissions {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id       String                @unique @db.Uuid
  screenshot_url       String?
  posted_at            DateTime?             @db.Timestamptz(6)
  disclosure_confirmed Boolean               @default(false)
  submitted_at         DateTime?             @db.Timestamptz(6)
  status               String                @default("pending")
  sponsor_notes        String?
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime              @updatedAt @db.Timestamptz(6)
  proof_urls           String[]
  admin_notes          String?
  payout_status        String?
  stripe_transfer_id   String?
  ctr                  Decimal?              @db.Decimal(6, 2)
  video_views          Json?
  views_fetched_at     DateTime?             @db.Timestamptz(6)
  application          campaign_applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model link_clicks {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String                @db.Uuid
  clicked_at     DateTime              @default(now()) @db.Timestamptz(6)
  ip_hash        String?
  user_agent     String?
  referrer       String?
  application    campaign_applications @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@index([clicked_at])
}

model sponsor_age_restriction_requests {
  id                             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sponsor_id                     String   @db.Uuid
  requested_age_restricted       Boolean
  requested_age_restriction_type String?
  sponsor_message                String
  status                         String   @default("pending")
  admin_notes                    String?
  created_at                     DateTime @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime @updatedAt @db.Timestamptz(6)
  sponsor                        sponsors @relation(fields: [sponsor_id], references: [id], onDelete: Cascade)

  @@index([sponsor_id])
  @@index([status])
}
